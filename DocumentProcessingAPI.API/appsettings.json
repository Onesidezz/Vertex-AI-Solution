{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=DocumentProcessingDB;Trusted_Connection=true;TrustServerCertificate=true",
    "PostgresConnection": "Host=localhost;Port=5432;Database=DocEmbeddings;Username=postgres;Password=Oneside@2"
  },
  "Gemini": {
    "ApiKey": "AIzaSyCghrweFyMWPstRzQJlJyQDLYs9du1IhKs",
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta",
    "EmbeddingModel": "models/gemini-embedding-001",
    "EmbeddingDimension": "3072",
    "OutputDimensionality": "3072",
    "MaxTokens": "8192"
  },
  "FileStorage": {
    "BasePath": "./uploads"
  },
  "Embeddings": {
    "StoragePath": "C:\\Users\\ukhan2\\Desktop\\DocProcessing embeddings\\DocumentProcessingAPI\\Embeddings"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*/upload",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*/search",
        "Period": "1m",
        "Limit": 50
      }
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/documentprocessing-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "TRIM": {
    "DataSetId": "UM",
    "WorkgroupServerUrl": "OTX-1Y0GDY3",
    "TimeoutSeconds": 300
  },
  "RecordSync": {
    "Enabled": "true",
    "CronSchedule": "0 0 * * * ?",
    "SearchString": "*",
    "Description": "Cron schedule for syncing Content Manager records. Default: 0 0 * * * ? (every hour at minute 0). Format: second minute hour day month dayOfWeek"
  }
}
