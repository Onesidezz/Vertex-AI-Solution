  "FileStorage": {
    "BasePath": "./uploads"
  },
  "Embeddings": {
    "StoragePath": "C:\\Users\\ukhan2\\Desktop\\DocProcessing embeddings\\DocumentProcessingAPI\\Embeddings"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*/upload",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*/search",
        "Period": "1m",
        "Limit": 50
      }
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/documentprocessing-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": null,
          "rollOnFileSizeLimit": false,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Authentication": {
    "EnableWindowsAuthentication": true
  },
  "TRIM": {
    "DataSetId": "UM",
    "WorkgroupServerUrl": "OTX-1Y0GDY3",
    "TimeoutSeconds": 300
  },
  "RecordSync": {
    "Enabled": "true",
    "CronSchedule": "0 0 * * * ?",
    "SearchString": "*",
    "PageSize": 1000,
    "MaxParallelTasks": 10,
    "CheckpointInterval": 10,
    "Description": "Cron schedule for syncing Content Manager records. Default: 0 0 * * * ? (every hour at minute 0). Format: second minute hour day month dayOfWeek. PageSize: records per page (default 1000). MaxParallelTasks: concurrent record processing (default 10). CheckpointInterval: save checkpoint every N pages (default 10)."
  }
